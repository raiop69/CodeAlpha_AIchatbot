<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ChatController">

    <center>

        <VBox spacing="10" styleClass="mainBox">

            <ScrollPane fitToWidth="true" prefWidth="752.0" VBox.vgrow="ALWAYS">

                <VBox fx:id="chatBox" prefWidth="750" spacing="10">

                    <padding>
                        <Insets bottom="10" left="10" right="10" top="10" />
                    </padding>

                </VBox>

            </ScrollPane>

            <HBox spacing="10" styleClass="inputArea">

                <TextField fx:id="inputField" onAction="#sendMessage" promptText="Type your message..." HBox.hgrow="ALWAYS" />

                <Button onAction="#sendMessage" text="Send" />

            </HBox>

        </VBox>

    </center>

</BorderPane>
